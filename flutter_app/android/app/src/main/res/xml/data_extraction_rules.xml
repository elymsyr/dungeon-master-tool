<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ extraction rules. Cloud backup + device-to-device
     transfer both include all user data (files + DB + prefs). -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="." />
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="." />
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
